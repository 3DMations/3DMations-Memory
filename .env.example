# Claude Memory Hub — environment variables
# Copy to .env and fill in values before running docker compose up

# Database password for the claude_memory PostgreSQL user
DB_PASSWORD=change_me_in_production

# Shared API key for hub authentication (used by all clients)
# Generate with: openssl rand -hex 32
API_KEY=change_me_in_production

# Log level for the FastAPI service (debug|info|warning|error)
LOG_LEVEL=info

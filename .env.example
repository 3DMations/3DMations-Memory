# 3DMations Memory Hub — example environment file
# Copy to .env and fill in real values. .env is gitignored; this file is not.

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=memories
POSTGRES_USER=hub
POSTGRES_PASSWORD=changeme

# --- App --------------------------------------------------------------------
# APP_PORT only used by the `app-debug` profile (loopback bind). Production
# `app` service has no host port — tailnet is the only ingress.
APP_PORT=3000

# Admin token for legacy DELETE auth (Phase 1.6 stopgap; Phase 3 replaces with
# Tailscale-identity gating via Tailscale-User-Login header).
AUTH_SECRET=changeme

# --- Ollama (Phase 1.5) -----------------------------------------------------
AI_FEATURES_ENABLED=false
OLLAMA_URL=http://jarvis-ollama:11434
OLLAMA_MODEL=qwen3.6:35b

# --- Tailscale (Phase 3a) ---------------------------------------------------
# Mint a reusable, non-ephemeral, tagged auth key in the Tailscale admin
# console: https://login.tailscale.com/admin/settings/keys
#   - Reusable: yes (so containers can re-register after `docker compose down`)
#   - Ephemeral: NO (state persists across restarts)
#   - Tags: tag:hub  (must be defined in tailnet ACL policy first)
# Format: tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXX
TS_AUTHKEY=

# --- Phase 3b (placeholder, not active until 3b lands) ----------------------
# Email/login of the user authorized to call /api/memories/verify.
# Compared verbatim against the Tailscale-User-Login header injected by Serve.
HUB_ADMIN_LOGIN=
